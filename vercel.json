{
    "buildCommand": "npm run build",
    "outputDirectory": "backend/static",
    "installCommand": "npm install && pip install -r backend/requirements.txt",
    "functions": {
      "api/index.py": {
        "maxDuration": 30,
        "includeFiles": "backend/**"
      }
    },
    "routes": [
      { "src": "/api/(.*)", "dest": "/api/index.py" },
      { "handle": "filesystem" },
      { "src": "/(.*)", "dest": "/index.html" }
    ]
  }